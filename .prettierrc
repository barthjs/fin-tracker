{
    "$schema": "https://json.schemastore.org/prettierrc",
    "plugins": [
        "prettier-plugin-blade",
        "prettier-plugin-tailwindcss"
    ],
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 4,
    "semi": true,
    "overrides": [
        {
            "files": [
                "*.blade.php"
            ],
            "options": {
                "parser": "blade"
            }
        }
    ]
}
