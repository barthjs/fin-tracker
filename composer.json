{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "barthjs/fin-tracker",
    "type": "project",
    "description": "Household Finance Manager",
    "homepage": "https://github.com/barthjs/fin-tracker",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "awcodes/light-switch": "^3.0",
        "bezhansalleh/filament-language-switch": "^4.2",
        "dedoc/scramble": "^0.13.17",
        "filament/filament": "^5.4.2",
        "jenssegers/agent": "^2.6.4",
        "laravel/framework": "^13.2",
        "laravel/sanctum": "^4.3.1",
        "laravel/socialite": "^5.26.0",
        "socialiteproviders/authelia": "^4.0",
        "socialiteproviders/authentik": "^5.3",
        "socialiteproviders/gitea": "^4.1",
        "socialiteproviders/keycloak": "^5.3",
        "spatie/laravel-query-builder": "^6.4.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24.1",
        "fruitcake/laravel-debugbar": "^4.2",
        "larastan/larastan": "^3.9.3",
        "laravel/pint": "^1.29.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "pestphp/pest": "^4.4.3",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "pestphp/pest-plugin-livewire": "^4.1.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.3"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup-dev": [
            "composer install",
            "npm install",
            "npm run build",
            "@publish-assets",
            "@php -r \"file_exists('.env') || copy('.env.development', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate",
            "@php artisan db:seed",
            "@php artisan storage:link"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan livewire:publish --assets",
            "@php artisan filament:upgrade",
            "@php artisan clear",
            "@update:requirements"
        ],
        "publish-assets": [
            "@php artisan livewire:publish --assets"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u"
        ],
        "lint": "pint --parallel",
        "test:type-coverage": "pest --type-coverage --compact --min=100",
        "test:unit": "pest --parallel",
        "test:lint": "pint --parallel --test",
        "test:types": "phpstan",
        "test": [
            "@php artisan config:clear",
            "@test:type-coverage",
            "@test:unit",
            "@test:lint",
            "@test:types"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
